&none  &none  &none  &none  &none  &none  &none  &none     &none  &none
&none  &none  &none  &none  &none  &none  &none  &kp HOME  &none  &none  &kp END
&none  &none  &none  &none  &none  &none  &none  &none     &none  &none
       &none  &none  &none  &none  &none  &none  &none     &none  &none  &none    &none
            >;
        };

        Colemak_Plain_and_Hyper {
            bindings = <
&kp Q           &kp W   &kp F   &kp P   &kp G   &kp J   &kp L   &kp U      &kp Y    &kp LEFT_SHIFT
&kp LEFT_SHIFT  &kp A   &kp R   &kp S   &kp T   &kp D   &kp H   &kp N      &kp E    &kp I           &kp O
&kp Z           &kp X   &kp C   &kp V   &kp B   &kp K   &kp M   &kp COMMA  &kp DOT  &kp FSLH
                &trans  &trans  &trans  &trans  &trans  &trans  &trans     &trans   &trans          &trans  &trans
            >;
        };

        Adjust {
            display-name = "BT, workarounds";
            bindings = <
&tog_on 2  &none       &tog 3      &none       &tog 7        &none         &trans      &Ubuntu_Macro  &none    &tog 25
&none      &none       &bt BT_PRV  &bt BT_NXT  &bt BT_SEL 2  &bt BT_SEL 3  &trans      &trans         &trans   &iPad_Macro  &none
&trans     &trans      &tog_of 2   &kp INSERT  &out OUT_BLE  &none         &Mac_Macro  &trans         &none    &none
           &sys_reset  &none       &none       &none         &none         &none       &sys_reset     &kt F15  &bt BT_CLR   &none  &none
            >;
        };

        Apps {
            bindings = <
&App_Q_TD  &App_W_TD  &App_F_TD  &App_P_TD  &App_G_TD  &App_J_TD  &App_L_TD  &App_U_TD  &App_Y_TD  &none
&none      &App_A_TD  &App_R_TD  &App_S_TD  &App_T_TD  &App_D_TD  &App_H_TD  &App_N_TD  &App_E_TD  &App_I_TD  &App_O_TD
&App_Z_TD  &App_X_TD  &App_C_TD  &App_V_TD  &App_B_TD  &App_K_TD  &App_M_TD  &none      &none      &none
           &none      &none      &none      &none      &none      &none      &none      &none      &none      &none      &none
            >;
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";

        MouseWarpConditional {
            if-layers = <22>;
            then-layer = <21>;
        };

        MousePrecisionConditional {
            if-layers = <23>;
            then-layer = <21>;
        };

        MouseRegularConditional {
            if-layers = <24>;
            then-layer = <21>;
        };
    };
};
